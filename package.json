{
  "name": "lattice",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejohane/lattice.git"
  },
  "scripts": {
    "build": "bun run mac:bundle",
    "package:mac-app": "bash scripts/package-mac-app.sh",
    "package:mac-dev-update": "bash scripts/package-mac-dev-update.sh",
    "mac:build": "xcodebuild -workspace apps/Lattice/Lattice.xcworkspace -scheme LatticeMac -configuration Debug -destination 'generic/platform=macOS' build",
    "mac:run": "bun run mac:bundle && open dist/Lattice.app",
    "mac:test": "swift test --package-path apps/Lattice",
    "mac:bundle": "bash scripts/build-mac-app.sh",
    "ios:build": "xcodebuild -workspace apps/Lattice/Lattice.xcworkspace -scheme LatticeiOS -destination 'generic/platform=iOS Simulator' build",
    "test": "bun run mac:test",
    "verify": "bun run mac:test && bun run mac:build && bun run ios:build",
    "release:plan": "node scripts/plan-release.mjs",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^25.0.3"
  }
}
