{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          {
            "breaking": true,
            "release": "major"
          },
          {
            "type": "feat",
            "release": "minor"
          },
          {
            "type": "build",
            "release": "patch"
          },
          {
            "type": "chore",
            "release": "patch"
          },
          {
            "type": "ci",
            "release": "patch"
          },
          {
            "type": "docs",
            "release": "patch"
          },
          {
            "type": "fix",
            "release": "patch"
          },
          {
            "type": "perf",
            "release": "patch"
          },
          {
            "type": "refactor",
            "release": "patch"
          },
          {
            "type": "revert",
            "release": "patch"
          },
          {
            "type": "style",
            "release": "patch"
          },
          {
            "type": "test",
            "release": "patch"
          }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "release-artifacts/lattice-darwin-arm64.tar.gz",
            "label": "lattice-darwin-arm64.tar.gz"
          },
          {
            "path": "release-artifacts/lattice-darwin-arm64.tar.gz.sha256",
            "label": "lattice-darwin-arm64.tar.gz.sha256"
          },
          {
            "path": "release-artifacts/lattice-darwin-x64.tar.gz",
            "label": "lattice-darwin-x64.tar.gz"
          },
          {
            "path": "release-artifacts/lattice-darwin-x64.tar.gz.sha256",
            "label": "lattice-darwin-x64.tar.gz.sha256"
          },
          {
            "path": "release-artifacts/lattice-linux-x64.tar.gz",
            "label": "lattice-linux-x64.tar.gz"
          },
          {
            "path": "release-artifacts/lattice-linux-x64.tar.gz.sha256",
            "label": "lattice-linux-x64.tar.gz.sha256"
          }
        ]
      }
    ]
  ]
}
